# Copy to .env for running the API directly on your host (outside Docker).
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# Postgres (docker-compose exposes it on host port 5432)
DATABASE_URL=postgres://truerestore:truerestore@localhost:5432/truerestore

# MinIO — host == localhost when the API runs on your machine
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=truerestore-media

CORS_ALLOW_ALL_ORIGINS=true
