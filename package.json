{
  "name": "truerestore-interview",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "dev": "./scripts/dev.sh",
    "dev:ios": "MOBILE_PLATFORM=ios ./scripts/dev.sh",
    "dev:android": "MOBILE_PLATFORM=android ./scripts/dev.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:web": "yarn workspace web dev",
    "dev:mobile": "yarn workspace mobile dev",
    "infra:up": "docker compose up -d db minio createbuckets",
    "infra:down": "docker compose down",
    "stack:up": "docker compose up --build",
    "stack:down": "docker compose down -v",
    "stack:clean": "docker compose down -v --rmi local --remove-orphans && docker compose up --build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3"
  },
  "dependencies": {
    "expo": "~55.0.27",
    "react": "19.2.0",
    "react-native": "0.83.6"
  }
}
